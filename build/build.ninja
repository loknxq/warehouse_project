# Utility command for edit_cache

build _deps/catch2-build/src/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D D:\warehouse_project\build\_deps\catch2-build\src && C:\msys64\mingw64\bin\cmake.exe -E echo "No interactive CMake dialog available.""
