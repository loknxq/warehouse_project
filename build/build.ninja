build WarehouseLib: phony libWarehouseLib.a

build WarehouseTests: phony WarehouseTests.exe

build libCatch2Maind.a: phony _deps/catch2-build/src/libCatch2Maind.a

build libCatch2d.a: phony _deps/catch2-build/src/libCatch2d.a

